{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Tool calls / sec",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [{
        "expr": "sum by (tool) (rate(malaysia_data_tool_calls_total[1m]))",
        "legendFormat": "{{tool}}"
      }],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "title": "Tool error rate",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [{
        "expr": "sum by (tool) (rate(malaysia_data_tool_calls_total{outcome=\"error\"}[5m]))",
        "legendFormat": "{{tool}}"
      }],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "title": "Tool call latency p95",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [{
        "expr": "histogram_quantile(0.95, sum by (le, tool) (rate(malaysia_data_tool_call_duration_seconds_bucket[5m])))",
        "legendFormat": "{{tool}}"
      }],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
    },
    {
      "title": "Cache hit rate (L1)",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [{
        "expr": "sum(rate(malaysia_data_cache_operations_total{layer=\"l1\",outcome=\"hit\"}[5m])) / sum(rate(malaysia_data_cache_operations_total{layer=\"l1\",outcome=~\"hit|miss\"}[5m]))"
      }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 } },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 }
    },
    {
      "title": "Upstream errors",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [{
        "expr": "sum by (upstream, status) (rate(malaysia_data_upstream_requests_total{status!=\"2xx\"}[5m]))",
        "legendFormat": "{{upstream}} {{status}}"
      }],
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["malaysia-data", "mcp"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "title": "Malaysia Data MCP — Service",
  "version": 1,
  "weekStart": ""
}
