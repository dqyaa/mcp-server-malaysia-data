# Copy to .env for local dev. All settings are optional with sensible defaults.

# --- Service identity ---
MALAYSIA_DATA_ENVIRONMENT=dev
MALAYSIA_DATA_SERVICE_NAME=malaysia-data-mcp

# --- Logging ---
MALAYSIA_DATA_LOG_LEVEL=INFO
MALAYSIA_DATA_LOG_JSON=false   # set true in prod for JSON logs

# --- HTTP client tunables ---
MALAYSIA_DATA_HTTP_TIMEOUT_SECONDS=10
MALAYSIA_DATA_HTTP_MAX_RETRIES=3

# --- Rate limits (per upstream, per minute) ---
MALAYSIA_DATA_BNM_RATE_LIMIT_PER_MINUTE=60
MALAYSIA_DATA_DATAGOVMY_RATE_LIMIT_PER_MINUTE=60

# --- Circuit breaker ---
MALAYSIA_DATA_CIRCUIT_FAILURE_THRESHOLD=5
MALAYSIA_DATA_CIRCUIT_RECOVERY_SECONDS=30

# --- Cache ---
MALAYSIA_DATA_CACHE_DEFAULT_TTL_SECONDS=300
MALAYSIA_DATA_CACHE_L1_MAX_SIZE=1024
# Uncomment to enable shared L2 cache:
# MALAYSIA_DATA_CACHE_REDIS_URL=redis://localhost:6379/0

# --- Observability ---
MALAYSIA_DATA_METRICS_ENABLED=true
MALAYSIA_DATA_OTEL_ENABLED=false
# MALAYSIA_DATA_OTEL_ENDPOINT=http://localhost:4318
# MALAYSIA_DATA_SENTRY_DSN=

# --- HTTP REST server ---
MALAYSIA_DATA_HTTP_HOST=0.0.0.0
MALAYSIA_DATA_HTTP_PORT=8000
